{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "ATLAS",
  "version": "0.1.0",
  "identifier": "ai.atlas.desktop",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://127.0.0.1:5173",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "ATLAS Command Center",
        "width": 1500,
        "height": 940,
        "minWidth": 1180,
        "minHeight": 760,
        "resizable": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all"
  }
}
